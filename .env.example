# OpenEOS Landing - Environment Configuration
#
# Copy to `.env.local` for local dev. In production, place a `.env` file next
# to `docker-compose.yml` on the server with the real values — docker compose
# picks it up automatically and forwards the IMPRINT_* vars into the container
# (see `environment:` block in docker-compose.yml). Real values must NEVER be
# committed to the repo.

# ---------------------------------------------------------------------------
# Public URLs (NEXT_PUBLIC_*) — embedded at build time, exposed to the browser
# ---------------------------------------------------------------------------

# Base URL of the OpenEOS web app (login/register targets)
NEXT_PUBLIC_APP_URL=https://app.openeos.de

# Optional: Base URL of the API (if referenced from client code)
NEXT_PUBLIC_API_URL=https://api.openeos.de

# Optional: Documentation URL used by the "Self-Hosted" pricing CTA
NEXT_PUBLIC_DOCS_URL=https://docs.openeos.de

# Optional: Contact email used in mailto: links (e.g. hardware / gateway CTAs)
NEXT_PUBLIC_CONTACT_EMAIL=kontakt@openeos.de

# Optional: Demo request email (mailto target for "Demo anfragen" buttons)
NEXT_PUBLIC_DEMO_EMAIL=hello@openeos.de

# ---------------------------------------------------------------------------
# Imprint / Privacy — server-side only, read at request time
# (no NEXT_PUBLIC_ prefix → never shipped to the browser bundle)
# ---------------------------------------------------------------------------

IMPRINT_NAME=
IMPRINT_STREET=
IMPRINT_CITY=
IMPRINT_COUNTRY=Deutschland
IMPRINT_EMAIL=kontakt@openeos.de
IMPRINT_PHONE=
IMPRINT_VAT_ID=
